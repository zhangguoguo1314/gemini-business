# Dockerfile for Gemini Business API - HF Spaces 版本
# 精简版：不含 Chrome/Xvfb，禁用注册服务，适配 HF Spaces 环境
FROM python:3.11-slim

WORKDIR /app

# 安装基础依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件并安装
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制项目文件
COPY main.py .
COPY core ./core
COPY util ./util
COPY templates ./templates
COPY static ./static

# 创建数据目录
RUN mkdir -p /data/images

# 环境变量
ENV DATA_DIR=/data
ENV ENABLE_REGISTER_SERVICE=false
ENV TZ=Asia/Shanghai
ENV PORT=7860

EXPOSE 7860

CMD ["python", "-u", "main.py"]
